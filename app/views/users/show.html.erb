<div class="max-w-2xl mx-auto">
  <!-- User Profile Header -->
  <div class="bg-gray-800 rounded-lg shadow-lg p-6 mb-6 border border-gray-700">
    <div class="flex items-center space-x-4">
      <div class="w-20 h-20 bg-gray-600 rounded-full flex items-center justify-center">
        <% if @user.avatar.present? %>
          <%= image_tag @user.avatar, class: "w-20 h-20 rounded-full object-cover" %>
        <% else %>
          <span class="text-gray-300 font-semibold text-3xl">
            <%= @user.display_name&.first&.upcase || @user.username&.first&.upcase || "U" %>
          </span>
        <% end %>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-white"><%= @user.display_name %></h1>
        <p class="text-gray-400">@<%= @user.username %></p>
        <p class="text-gray-500 mt-1"><%= @user.email %></p>
      </div>
    </div>
  </div>

  <!-- User Stats -->
  <div class="bg-gray-800 rounded-lg shadow-lg p-4 mb-6 border border-gray-700">
    <div class="grid grid-cols-4 gap-4 text-center">
      <div>
        <div class="text-2xl font-bold text-white"><%= @parent_less_tweets.count %></div>
        <div class="text-gray-400 text-sm">Reets</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= @replies.count %></div>
        <div class="text-gray-400 text-sm">Replies</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= @likes.count %></div>
        <div class="text-gray-400 text-sm">Likes</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= @shares.count %></div>
        <div class="text-gray-400 text-sm">Shares</div>
      </div>
    </div>
  </div>

  <!-- User's Content -->
  <div class="space-y-6">
    <!-- Parent-less Tweets -->
    <div class="bg-gray-800 rounded-lg shadow-lg border border-gray-700">
      <div class="p-4 border-b border-gray-700">
        <h3 class="text-lg font-semibold text-white">Reets</h3>
      </div>
      <div class="p-4">
        <div class="space-y-4">
          <% @parent_less_tweets.each do |tweet| %>
            <%= render 'tweets/tweet', tweet: tweet %>
          <% end %>
          
          <% if @parent_less_tweets.empty? %>
            <div class="text-center text-gray-400 py-8">
              <p>No reets yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Replies -->
    <div class="bg-gray-800 rounded-lg shadow-lg border border-gray-700">
      <div class="p-4 border-b border-gray-700">
        <h3 class="text-lg font-semibold text-white">Replies</h3>
      </div>
      <div class="p-4">
        <div class="space-y-4">
          <% @replies.each do |reply| %>
            <div class="border-l-4 border-blue-500 pl-4">
              <%= render 'tweets/tweet', tweet: reply %>
            </div>
          <% end %>
          
          <% if @replies.empty? %>
            <div class="text-center text-gray-400 py-8">
              <p>No replies yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Shares -->
    <div class="bg-gray-800 rounded-lg shadow-lg border border-gray-700">
      <div class="p-4 border-b border-gray-700">
        <h3 class="text-lg font-semibold text-white">Shares</h3>
      </div>
      <div class="p-4">
        <div class="space-y-4">
          <% @shares.each do |share| %>
            <div class="border-l-4 border-green-500 pl-4">
              <div class="text-green-400 text-sm mb-2">
                <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/>
                </svg>
                Shared by @<%= @user.username %>
              </div>
              <%= render 'tweets/tweet', tweet: share.tweet %>
            </div>
          <% end %>
          
          <% if @shares.empty? %>
            <div class="text-center text-gray-400 py-8">
              <p>No shares yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Likes -->
    <div class="bg-gray-800 rounded-lg shadow-lg border border-gray-700">
      <div class="p-4 border-b border-gray-700">
        <h3 class="text-lg font-semibold text-white">Likes</h3>
      </div>
      <div class="p-4">
        <div class="space-y-4">
          <% @likes.each do |like| %>
            <div class="border-l-4 border-red-500 pl-4">
              <div class="text-red-400 text-sm mb-2">
                <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
                Liked by @<%= @user.username %>
              </div>
              <%= render 'tweets/tweet', tweet: like.tweet %>
            </div>
          <% end %>
          
          <% if @likes.empty? %>
            <div class="text-center text-gray-400 py-8">
              <p>No likes yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
