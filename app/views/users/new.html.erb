<div class="max-w-md mx-auto mt-8 p-6 bg-gray-800 rounded-lg shadow-lg border border-gray-700">
  <h1 class="text-2xl font-bold mb-6 text-center text-white">Create Account</h1>
  
  <%= form_with model: @user, local: true, class: "space-y-4" do |form| %>
    <% if @user.errors.any? %>
      <div class="bg-red-900 border border-red-700 text-red-200 px-4 py-3 rounded">
        <h2 class="font-bold">Please fix the following errors:</h2>
        <ul class="list-disc list-inside">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :username, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.text_field :username, 
          class: "w-full p-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :email, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.email_field :email, 
          class: "w-full p-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :display_name, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.text_field :display_name, 
          class: "w-full p-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :avatar, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.text_field :avatar, 
          placeholder: "Avatar URL (optional)",
          class: "w-full p-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :password, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.password_field :password, 
          class: "w-full p-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :password_confirmation, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.password_field :password_confirmation, 
          class: "w-full p-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div class="pt-4">
      <%= form.submit "Create Account", 
          class: "w-full bg-blue-500 text-white py-3 px-4 rounded-lg font-semibold hover:bg-blue-600 transition-colors" %>
    </div>
  <% end %>

  <div class="mt-6 text-center">
    <%= link_to "Already have an account? Sign in", "#", 
        class: "text-blue-400 hover:text-blue-300" %>
  </div>
</div>
