<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Ritter" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <% if Rails.env.development? %>
      <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
      <meta http-equiv="Pragma" content="no-cache">
      <meta http-equiv="Expires" content="0">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%# Includes all JavaScript files in app/javascript %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-900 text-white min-h-screen">
    <!-- Navigation -->
    <nav class="bg-gray-800 border-b border-gray-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to root_path, class: "text-xl font-bold text-white hover:text-gray-300" do %>
              Ritter
            <% end %>
          </div>
          <div class="flex items-center space-x-4">
            <% if logged_in? %>
              <%= link_to current_user.display_name, user_path(current_user), class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
              <%= button_to "Logout", logout_path, method: :delete, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium bg-transparent border-none cursor-pointer" %>
            <% else %>
              <%= link_to "Login", login_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
              <%= link_to "Sign Up", new_user_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-600 text-white px-4 py-3 rounded mb-4 mx-auto max-w-2xl mt-4">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="bg-red-600 text-white px-4 py-3 rounded mb-4 mx-auto max-w-2xl mt-4">
        <%= alert %>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-2xl mx-auto px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
