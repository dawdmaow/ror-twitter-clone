<div class="max-w-2xl mx-auto">
  <!-- Back to Feed -->
  <%= link_to "← Back to Feed", tweets_path, class: "text-blue-400 hover:text-blue-300 mb-4 inline-block" %>
  
  <!-- Main Tweet -->
  <%= render 'tweets/tweet', tweet: @tweet %>

  <!-- Reply Form -->
  <% if logged_in? %>
    <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700 mt-6">
      <h3 class="text-lg font-semibold text-white mb-4">Reply to this reet</h3>
      <%= form_with model: Tweet.new, local: true, class: "space-y-4" do |form| %>
        <%= form.hidden_field :parent_tweet_id, value: @tweet.id %>
        
        <div>
          <%= form.label :content, "Your reply", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= form.text_area :content, required: true, rows: 3, class: "w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-md text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        </div>
        
        <div>
          <%= form.label :media_url, "Media URL (optional)", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= form.url_field :media_url, class: "w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-md text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        </div>
        
        <%= form.submit "Reply", class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-800" %>
      <% end %>
    </div>
  <% end %>

  <!-- Replies -->
  <div class="mt-6">
    <h3 class="text-lg font-semibold text-white mb-4">Replies</h3>
    <div class="space-y-4">
      <% @replies.each do |reply| %>
        <%= render 'tweets/tweet', tweet: reply, is_reply: true %>
      <% end %>
      
      <% if @replies.empty? %>
        <div class="text-center text-gray-400 py-8">
          <p>No replies yet. Be the first to reply!</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
